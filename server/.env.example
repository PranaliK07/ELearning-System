# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=learning_db
DB_PORT=3306
DB_SYNC_ON_START=true
SEQUELIZE_SYNC_ALTER=false

# JWT
JWT_SECRET=replace_with_a_strong_secret
JWT_REFRESH_SECRET=replace_with_a_strong_refresh_secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Optional: Parent SMS + WhatsApp delivery for Class Communication (Twilio)
# - Used only when audience is "parents" or "both"
# - If TWILIO_* vars are missing, messages are skipped and in-app notifications still work
PHONE_DEFAULT_COUNTRY_CODE=+91
PARENTS_SMS_ENABLED=true
PARENTS_WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM= +14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Upload
MAX_FILE_SIZE=104857600
ALLOWED_VIDEO_TYPES=video/mp4,video/mpeg,video/quicktime
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@elearning.com
CONTACT_EMAIL=hello@elslearning.com

# Initial admin
ADMIN_EMAIL=admin@elearning.com
ADMIN_PASSWORD=Admin@123
